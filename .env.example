# Copiar para `.env` na raiz de `backend_min` e ajustar.
# O ficheiro `.env` não deve ser commitado.

# --- Base de dados ---
# Local (por defeito se omitido no código)
DATABASE_URL=sqlite:///./test.db

# Beta / produção online (ex.: PostgreSQL no Render, Railway, etc.)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
#
# Se no Windows der "SSL connection has been closed unexpectedly" ao Render:
# 1) pip install pg8000
# 2) DATABASE_DRIVER=pg8000
# Ou usar WSL / outra rede (VPN desligada).
# DATABASE_DRIVER=pg8000

# --- CORS (browser a falar com a API) ---
# URL pública do frontend (sem barra no fim). Obrigatório se o site não for localhost.
# FRONTEND_URL=https://teu-frontend.vercel.app

# Origens extra, separadas por vírgula (preview Vercel, segundo domínio, etc.)
# CORS_EXTRA_ORIGINS=https://preview-xxx.vercel.app,https://outro-dominio.pt

# --- Segurança ---
# Em beta/produção, definir um segredo forte (JWT).
# SECRET_KEY=alterar-para-um-valor-longo-e-aleatorio

# --- OpenAPI / Swagger “Try it out” (ex.: Render) ---
# RENDER_EXTERNAL_URL=https://teu-backend.onrender.com

# --- Import PDF (opcional; caminhos por defeito no Windows no código) ---
# Em Linux/servidor (beta), usar caminhos absolutos onde os PDF estão montados.
#
# --- Render.com + Persistent Disk (recomendado) ---
# No painel: Web Service → Disks → Add Disk → mount path: /var/data/pdf_escalas (ex.: 1 GB).
# Depois, no Render Shell:  sh scripts/render-mkdir-pdf-dirs.sh
# Colocar os PDF em .../atual e .../seguinte (ver DEPLOY_BETA_LIMPO.md).
# PDF_FOLDER_ATUAL=/var/data/pdf_escalas/atual
# PDF_FOLDER_SEGUINTE=/var/data/pdf_escalas/seguinte

# --- Limpeza total de escalas (POST /import/clear-schedules) em produção ---
# Se definido, o header X-Clear-Schedules-Secret deve coincidir.
# CLEAR_SCHEDULES_SECRET=um-segredo-longo-para-beta
