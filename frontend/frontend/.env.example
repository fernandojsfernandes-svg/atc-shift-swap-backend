# Copiar para `.env.development` ou `.env.local` (não versionados).
# Vite só expõe variáveis com prefixo VITE_.

# URL base da API FastAPI — sem barra no fim.
# Desenvolvimento local (backend na mesma máquina):
VITE_API_URL=http://127.0.0.1:8000

# Se omitires VITE_API_URL em desenvolvimento: a app usa hostname:8000 (localhost / rede local).
# Build de produção (ex. Vercel) sem VITE_API_URL: usa o backend por defeito em App.tsx (Render).

# --- Build da beta online (recomendado no painel Vercel antes de `npm run build`) ---
# VITE_API_URL=https://atc-shift-swap-backend.onrender.com
